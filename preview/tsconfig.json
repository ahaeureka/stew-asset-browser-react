{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "rootDir": "..",
        "noEmit": true,
        "types": [
            "react",
            "react-dom"
        ]
    },
    "include": [
        "./**/*",
        "../src/**/*.d.ts",
        "../src/**/*.tsx"
    ],
    "exclude": [
        "../dist",
        "../node_modules",
        "./dist"
    ]
}